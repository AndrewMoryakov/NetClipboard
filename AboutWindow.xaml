<Window x:Class="NetClipboard.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About NetClipboard"
        Width="440" Height="390"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ThemeBase}">

    <Window.Resources>
        <Style x:Key="AboutBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ThemeSurface0}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeSurface2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeSurface1}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeSurface2}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="NetClipboard"
                       Foreground="{DynamicResource ThemeText}"
                       FontSize="20"
                       FontWeight="Bold"/>
            <TextBlock x:Name="VersionText"
                       Foreground="{DynamicResource ThemeSubtext0}"
                       FontSize="12"
                       Margin="0,3,0,0"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="{DynamicResource ThemeSurface0}"
                BorderBrush="{DynamicResource ThemeSurface1}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12">
            <StackPanel>
                <TextBlock Text="Repository"
                           Foreground="{DynamicResource ThemeText}"
                           FontSize="13"
                           FontWeight="SemiBold"/>
                <TextBlock Margin="0,4,0,12">
                    <Hyperlink x:Name="RepositoryLink"
                               Click="RepositoryLink_Click">
                        <Run Text="Open GitHub repository"/>
                    </Hyperlink>
                </TextBlock>

                <TextBlock Text="Updates"
                           Foreground="{DynamicResource ThemeText}"
                           FontSize="13"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Updates are delivered through GitHub Releases and verified with a SHA-256 manifest before install."
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource ThemeSubtext0}"
                           FontSize="12"
                           LineHeight="18"
                           Margin="0,4,0,10"/>

                <TextBlock x:Name="AvailableVersionText"
                           Text="No update selected."
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource ThemeText}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           LineHeight="18"
                           Margin="0,0,0,6"/>

                <TextBlock x:Name="UpdateStatusText"
                           Text="No update check has run in this window."
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource ThemeOverlay0}"
                           FontSize="12"
                           LineHeight="18"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="CheckUpdatesBtn"
                    Grid.Column="0"
                    Style="{StaticResource AboutBtn}"
                    Click="CheckUpdates_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets"
                               FontSize="13" Margin="0,0,6,0"
                               Foreground="{DynamicResource ThemeText}"/>
                    <TextBlock Text="Check for updates"
                               Foreground="{DynamicResource ThemeText}"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="1"
                    x:Name="InstallUpdateBtn"
                    Style="{StaticResource AboutBtn}"
                    Margin="8,0,0,0"
                    Click="InstallUpdate_Click"
                    IsEnabled="False">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets"
                               FontSize="13" Margin="0,0,6,0"
                               Foreground="{DynamicResource ThemeText}"/>
                    <TextBlock Text="Install update"
                               Foreground="{DynamicResource ThemeText}"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="2"
                    Style="{StaticResource AboutBtn}"
                    Margin="8,0,0,0"
                    Click="Releases_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets"
                               FontSize="13" Margin="0,0,6,0"
                               Foreground="{DynamicResource ThemeText}"/>
                    <TextBlock Text="View releases"
                               Foreground="{DynamicResource ThemeText}"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="4"
                    Style="{StaticResource AboutBtn}"
                    Click="Close_Click">
                <TextBlock Text="Close" Foreground="{DynamicResource ThemeText}"/>
            </Button>
        </Grid>
    </Grid>
</Window>
