<Window x:Class="NetClipboard.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NetClipboard" Height="160" Width="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource ThemeBase}">
    <StackPanel Margin="16">
        <TextBlock x:Name="PromptText" Text="Enter password"
                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"
                   Foreground="{DynamicResource ThemeText}"/>
        <PasswordBox x:Name="PasswordInput" FontSize="13" Padding="6,4"
                     Background="{DynamicResource ThemeSurface0}"
                     Foreground="{DynamicResource ThemeText}"
                     BorderBrush="{DynamicResource ThemeSurface2}"
                     KeyDown="PasswordInput_KeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Padding="16,4" Margin="0,0,8,0"
                    Click="Cancel_Click"
                    Background="{DynamicResource ThemeSurface0}"
                    Foreground="{DynamicResource ThemeText}"
                    BorderBrush="{DynamicResource ThemeSurface2}"/>
            <Button Content="OK" Padding="16,4" IsDefault="True"
                    Click="OK_Click"
                    Background="{DynamicResource ThemeSurface0}"
                    Foreground="{DynamicResource ThemeText}"
                    BorderBrush="{DynamicResource ThemeSurface2}"/>
        </StackPanel>
    </StackPanel>
</Window>
